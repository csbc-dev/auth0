AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_AUDIENCE=https://api.example.com
PORT=3000
# Comma-separated list of Origins allowed to open the WebSocket
# AND to read the /auth-config endpoint.
# Vite default ports for the example clients.
# Leaving this empty makes the server accept ANY origin — startup logs a
# fail-open warning. Set to a real allowlist before deploying anywhere.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
# Optional: WebSocket URL the /auth-config endpoint advertises to clients.
# When unset (recommended for dev), the URL is derived per-request from the
# Host / X-Forwarded-Proto headers so the same server works on localhost,
# behind reverse proxies, and on non-localhost hosts. Set explicitly only
# when the WS endpoint lives on a different host than the config endpoint.
# Example: PUBLIC_WS_URL=wss://api.example.com
